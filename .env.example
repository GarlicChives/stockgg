# Copy this file to .env and fill in real values
# Never commit .env to git
# 完整環境變數說明見 ARCHITECTURE.md §7

# === 必要 ===
SUPABASE_SERVICE_ROLE_KEY=eyJ...      # Supabase Edge Function 認證；DB 連線必要
GOOGLE_API_KEY=AIzaSy...              # Gemini（精煉、日報、議題、分類）
TAVILY_API_KEY=tvly-...               # 主題字典搜尋（app.tavily.com 免費 1000 次/月）

# === 選用 ===
HF_TOKEN=hf_...                       # Hugging Face token：避開 sentence-transformer 下載 rate limit
CHROME_DEBUG_PORT=9222                # Chrome CDP port，預設 9222
